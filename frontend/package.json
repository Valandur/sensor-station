		"@types/superagent": "^4.1.17",
		"@types/xml2js": "^0.4.11",
		"@typescript-eslint/eslint-plugin": "5.58.0",
		"@typescript-eslint/parser": "5.58.0",
		"eslint": "8.38.0",
		"eslint-config-prettier": "8.8.0",
		"eslint-plugin-svelte3": "4.0.0",
		"prettier": "2.8.7",
		"prettier-plugin-svelte": "2.10.0",
		"sass": "1.62.0",
		"svelte": "3.58.0",
		"svelte-check": "3.2.0",

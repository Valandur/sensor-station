{
	"name": "sensor-frontend",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"start": "REACT_APP_API_URL=http://localhost:2000 react-scripts start",
		"build": "react-scripts build",
		"build:zero": "REACT_APP_DISABLE_SENSOR=1 REACT_APP_DISABLE_UPLOAD=1 react-scripts build",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"serve": "serve -s build -p 3000"
	},
	"dependencies": {
		"@stitches/react": "1.2.6",
		"axios": "0.25.0",
		"date-fns": "2.28.0",
		"date-holidays": "3.14.2",
		"react": "17.0.2",
		"react-dom": "17.0.2",
		"react-router-dom": "6.2.1",
		"react-scripts": "5.0.0"
	},
	"devDependencies": {
		"@types/node": "17.0.16",
		"@types/react": "17.0.39",
		"@types/react-dom": "17.0.11",
		"@types/react-router-dom": "5.3.3",
		"@typescript-eslint/eslint-plugin": "5.11.0",
		"@typescript-eslint/parser": "5.11.0",
		"eslint": "8.8.0",
		"eslint-config-prettier": "8.3.0",
		"prettier": "2.5.1",
		"typescript": "4.5.5"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
